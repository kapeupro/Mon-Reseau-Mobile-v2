# ============================================================================
# ResiliaMap — .env.prod.example  (PRODUCTION)
# ----------------------------------------------------------------------------
# Copy to .env.prod (gitignored) and fill EVERY value. NO defaults are inherited
# in prod: docker-compose.prod.yml uses ${VAR:?...}, so an unset secret aborts
# the `up` instead of silently booting with a dev `changeme` password.
#
# Fastest path: `bash scripts/gen-secrets.sh` writes a populated .env.prod with
# fresh random secrets + assembled connection strings; you then fill DOMAIN,
# ACME_EMAIL and VITE_BASEMAP_STYLE_URL.
# ============================================================================

# --- Postgres (owner role) --------------------------------------------------
POSTGRES_USER=resiliamap
POSTGRES_PASSWORD=__CHANGE_ME__owner_password
POSTGRES_DB=resiliamap

# --- Read-only role password (db/30_roles.sql) ------------------------------
# IMPORTANT: db/30_roles.sql creates resiliamap_ro with a baked dev password.
# In prod you MUST rotate it ONCE after first boot (see DEPLOY.ResiliaMap.md):
#   ALTER ROLE resiliamap_ro PASSWORD '<this value>';
# and use that same value in the two RO connection strings below.
POSTGRES_RO_PASSWORD=__CHANGE_ME__readonly_password

# --- Connection strings (assembled from the above; service host is "db") ----
# Owner — ingest + migrations ONLY (writes + REFRESH).
DATABASE_URL=postgres://resiliamap:__CHANGE_ME__owner_password@db:5432/resiliamap
# Read-only — the API.
API_DATABASE_URL=postgres://resiliamap_ro:__CHANGE_ME__readonly_password@db:5432/resiliamap
# Read-only — pg_tileserv.
TILESERV_DATABASE_URL=postgres://resiliamap_ro:__CHANGE_ME__readonly_password@db:5432/resiliamap

# --- API --------------------------------------------------------------------
API_PORT=3801
# Leave empty: the browser reaches /api same-origin via Caddy -> web nginx, so
# cross-origin is denied (fail-safe). Only set if a separate front-end origin needs it.
CORS_ORIGIN=
# HMAC secret signing outgoing webhook alert payloads (E3).
WEBHOOK_SIGNING_SECRET=__CHANGE_ME__webhook_hmac_secret

# --- Web basemap (D2) -------------------------------------------------------
# REQUIRED in prod: the public OSM CDN forbids prod traffic. Use a licensed style
# (MapTiler/Stadia) and restrict the key by domain in the provider dashboard.
VITE_BASEMAP_STYLE_URL=https://api.maptiler.com/maps/streets/style.json?key=__YOUR_KEY__

# --- TLS / domain (Caddy) ---------------------------------------------------
DOMAIN=resiliamap.example.org
ACME_EMAIL=ops@example.org
