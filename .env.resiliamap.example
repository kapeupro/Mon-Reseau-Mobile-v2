# ============================================================================
# ResiliaMap — .env.resiliamap.example
# ----------------------------------------------------------------------------
# Copy to .env.resiliamap (which is gitignored) and adjust. NO REAL SECRETS here.
#   cp .env.resiliamap.example .env.resiliamap
#
# This env file is for the ResiliaMap stack ONLY (docker-compose.resiliamap.yml).
# It does NOT touch the existing Arcep app's config (back_mrm/config/.env).
#
# Host ports are deliberately shifted off the Arcep defaults (Arcep uses :8000)
# to avoid collisions when both stacks run on the same machine.
# ============================================================================

# --- PostgreSQL / PostGIS ---------------------------------------------------
POSTGRES_USER=resiliamap
POSTGRES_PASSWORD=changeme_local_only
POSTGRES_DB=resiliamap
# Host port exposed by the db service (container always listens on 5432).
DB_HOST_PORT=5440
# In-container host/port used by api/ingest/tileserv (compose service name "db").
DB_HOST=db
DB_PORT=5432

# Owner connection string for INGEST + MIGRATIONS only (reads + writes + REFRESH).
# When running tooling on the HOST (outside compose), use:
#   postgres://resiliamap:changeme_local_only@localhost:5440/resiliamap
DATABASE_URL=postgres://resiliamap:changeme_local_only@db:5432/resiliamap

# Read-only role for pg_tileserv (and optionally the API) — created by
# db/30_roles.sql with SELECT-only grants. Least privilege: it can never write
# or REFRESH the MV. Override the password in production (ALTER ROLE) and keep it
# in sync here. The API can also point at this RO role since api/src/db.ts is
# strictly read-only; keep the owner DATABASE_URL reserved for ingest/migrations.
TILESERV_DATABASE_URL=postgres://resiliamap_ro:changeme_local_only@db:5432/resiliamap

# --- API (Bun + Elysia) -----------------------------------------------------
API_PORT=3801

# CORS allowlist for the API. Comma-separated origins, e.g.
#   CORS_ORIGIN=https://resiliamap.fr,https://www.resiliamap.fr
# In production (NODE_ENV=production) an unset or '*' value DENIES cross-origin
# (the web nginx proxy serves the app same-origin, so this is safe). In dev it
# defaults to reflecting any origin so the Vite app can call the API directly.
NODE_ENV=production
CORS_ORIGIN=

# --- Vector tiles (pg_tileserv) ---------------------------------------------
# Host port for pg_tileserv (container listens on 7800).
TILESERV_HOST_PORT=7801
TILESERV_URL=http://localhost:7801

# --- Web (React + Vite) -----------------------------------------------------
WEB_HOST_PORT=8081
# Vite build-time env (mirrored into the web container). For local `make web-dev`
# these are read from web/.env via VITE_ prefixes. The browser reads VITE_API_URL
# (see web/src/api.ts); leave it empty in compose so the nginx proxy serves /api
# same-origin. Set it (e.g. http://localhost:3801) only for the direct-port dev path.
VITE_API_URL=http://localhost:3801
VITE_TILESERV_URL=http://localhost:7801

# --- Ingestion --------------------------------------------------------------
# Base URL for the dated sites-indisponibles GeoJSON (the archival CORE).
# Full pattern: {OUTAGE_BASE_URL}/{YYYY-MM-DD}/raw{YYYY-MM-DD}.geojson
# Confirmed in cron_update_site.py.
OUTAGE_BASE_URL=https://object.files.data.gouv.fr/arcep/sites-indisponibles/all

# Score constants overridable at ingest time (DB score_constants is source of
# truth; these are convenience defaults for ad-hoc loaders). Calibrate per pilot.
R_METERS=3000
OUTAGE_WINDOW_DAYS=90
